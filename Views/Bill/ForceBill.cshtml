@{
    ViewData["Title"] = "Force Bills";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/force-bill.css" asp-append-version="true" />
}

<div class="fb-page" id="view-forcebill">

    <input type="hidden" id="hidUID" value="@Context.Session.GetString("EmpUID")" />

    <!-- ── Toolbar (Force Bill · Export · Search) — matches Manage Employee ── -->
    <div class="tel-toolbar">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <button id="btnForceBillOpen" type="button" class="btn btn-add-tel btn-sm px-3">
                <i class="fa fa-bolt me-1"></i>Force Bill
            </button>
            <button id="btnExcelExport" type="button" class="btn btn-outline-success btn-sm px-3">
                <i class="fa fa-file-excel me-1"></i>Export to Excel
            </button>
        </div>
        <div class="tel-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input id="txtSearchForceBill" type="text" placeholder="Search bills…" autocomplete="off" />
        </div>
    </div>

    <!-- ── Themed grid (matches ManageProvider / AddTelephone) ─────────────── -->
    <div class="tel-grid-wrap">
        <table id="tblForceBill" class="table table-hover align-middle w-100">
            <thead>
                <tr>
                    <th class="text-center" style="width:36px">
                        <input type="checkbox" id="chkSelectAll" class="form-check-input" title="Select all" />
                    </th>
                    <th data-label="Bill Date">Bill Date</th>
                    <th data-label="Employee">Employee</th>
                    <th data-label="Manager">Manager</th>
                    <th data-label="Department">Department</th>
                    <th data-label="Mobile">Mobile</th>
                    <th data-label="Provider">Provider</th>
                    <th data-label="Amount" class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- ── Force Bill configuration modal ─────────────────────────────────── -->
<div class="modal fade tel-modal" id="modalForceBill" tabindex="-1" aria-labelledby="modalForceBillLabel"
     aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- Teal header -->
            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-bolt"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title" id="modalForceBillLabel">Force Bill Configuration</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <!-- Dropdowns -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label for="cmbCallType" class="tel-lbl"><i class="fa fa-phone"></i>Save unidentified calls as</label>
                        <select id="cmbCallType" class="form-select tel-input">
                            <option value="1">Business</option>
                            <option value="2" selected>Personal</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="cmbStatus" class="tel-lbl"><i class="fa fa-flag"></i>Set bill status to</label>
                        <select id="cmbStatus" class="form-select tel-input">
                            <option value="2">Waiting For Line Manager Approval</option>
                            <option value="4" selected>Closed</option>
                        </select>
                    </div>
                </div>

                <!-- Checkboxes -->
                <label class="tel-lbl"><i class="fa fa-sliders-h"></i>Additional Options</label>
                <div class="d-flex flex-wrap gap-4 pt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="chkWavRtl" />
                        <label class="form-check-label" for="chkWavRtl">Waive Rental Charges</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="chkWavBus" />
                        <label class="form-check-label" for="chkWavBus">Waive Business Charges</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="chkAlwTrain" />
                        <label class="form-check-label" for="chkAlwTrain">Allow Train</label>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Cancel
                </button>
                <button id="btnForceBill" type="button" class="btn btn-success">
                    <i class="fa fa-bolt me-1"></i>Force
                </button>
            </div>

        </div>
    </div>
</div>

<!-- ── Processing spinner overlay ─────────────────────────────────────── -->
<div id="spinnerOverlay" class="force-bill-spinner-overlay d-none">
    <div class="force-bill-spinner-box">
        <div class="spinner-border text-light mb-3" role="status"></div>
        <p class="text-white fw-semibold mb-0">Processing Force Bill&hellip;</p>
    </div>
</div>

@section Scripts {
    <script src="~/js/forceBill.js" asp-append-version="true"></script>
}
