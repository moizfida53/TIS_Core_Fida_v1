            Export to Excel
        </button>
    </div>

</div><!-- /view-manage-employee -->


<!-- ══════════════════════════════════════════════════════════════════════════
     EMPLOYEE MODAL  (Add / Edit)
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade tel-modal" id="employeeModal" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <!-- Teal header -->
            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-user-tie"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title" id="empModalTitle">Add Employee</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- Hidden state -->
                <input type="hidden" id="hidUID" />
                <!-- Extension hidden — preserved in payload but not shown in UI -->
                <input type="hidden" id="txtExtension" />

                <!-- ══ Row 1: Col-1 (Emp No + Username stacked) · Name · Department · Designation ══ -->
                <div class="row g-3 mb-4">

                    <!-- Column 1 — Emp No & Username side-by-side at equal widths -->
                    <div class="col-md-3">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="tel-lbl"><i class="fa fa-id-card"></i>Emp No.</label>
                                <input id="txtEmployeeNo" type="text" class="form-control tel-input" autocomplete="off" />
                            </div>
                            <div class="col-6">
                                <label class="tel-lbl"><i class="fa fa-user"></i>Username</label>
                                <input id="txtUsername" type="text" class="form-control tel-input" autocomplete="off" />
                            </div>
                        </div>
                    </div>

                    <!-- Column 2 — Employee Name -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-signature"></i>Employee Name</label>
                        <input id="txtName" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                    <!-- Column 3 — Department -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-building"></i>Department</label>
                        <input id="txtDept" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                    <!-- Column 4 — Designation -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-briefcase"></i>Designation</label>
                        <input id="txtDesc" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                </div>

                <!-- ══ Row 2: Payroll · Email · Cost Center · Company ══ -->
                <div class="row g-3 mb-4">

                    <!-- Payroll -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-money-check"></i>Payroll</label>
                        <input id="txtPayroll" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                    <!-- Email -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-envelope"></i>Email</label>
                        <input id="txtEmail" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                    <!-- Cost Center + (+) manage button -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-money-bill-wave"></i>Cost Center</label>
                        <div class="d-flex gap-2">
                            <div class="tel-picker flex-grow-1" data-picker="costCenter">
                                <input type="hidden" id="hidCC" />
                                <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                    Select Cost Center
                                </button>
                                <div class="dropdown-menu tel-picker-menu">
                                    <div class="tel-picker-search-wrap">
                                        <input type="text" class="tel-picker-search" placeholder="Search cost center…" autocomplete="off" />
                                    </div>
                                    <div class="tel-picker-list"></div>
                                </div>
                            </div>
                            <button type="button" id="btnOpenCC" class="emp-btn-add-cc" title="Manage Cost Centers"
                                    data-bs-toggle="modal" data-bs-target="#ccModal">
                                <i class="fa fa-plus"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Company -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-building"></i>Company</label>
                        <div class="tel-picker" data-picker="company">
                            <input type="hidden" id="hidCompany" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Company
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search company…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ══ Row 3: Manager · Role · Grade · Is Active ══ -->
                <div class="row g-3 align-items-end">

                    <!-- Select Manager -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-user-friends"></i>Select Manager</label>
                        <div class="tel-picker" data-picker="manager">
                            <input type="hidden" id="hidManager" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Manager
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search name or number…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Role -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-user-tag"></i>Role</label>
                        <div class="tel-picker" data-picker="role">
                            <input type="hidden" id="hidRole" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Role
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search role…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Grade -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-chart-line"></i>Grade</label>
                        <input id="txtGrade" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>

                    <!-- Is Active -->
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-check-circle"></i>Is Active</label>
                        <div class="emp-active-wrap">
                            <input type="checkbox" id="IsActive" class="emp-active-check" />
                        </div>
                    </div>

                </div>
            </div><!-- /modal-body -->

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Cancel
                </button>
                <button id="btnAdd" type="button" class="btn btn-success">
                    <i class="fa fa-plus-circle me-1"></i>Add
                </button>
                <button id="btnUpdate" type="button" class="btn btn-warning" style="display:none">
                    <i class="fa fa-edit me-1"></i>Update
                </button>
            </div>

        </div>
    </div>
</div>


<!-- ══════════════════════════════════════════════════════════════════════════
     COST CENTER MODAL
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade tel-modal" id="ccModal" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-money-bill-wave"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title">Manage Cost Centers</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="hidCID" />

                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-md-5">
                        <label class="tel-lbl">Cost Center Name</label>
                        <input id="txtCCName" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>
                    <div class="col-md-4">
                        <label class="tel-lbl">Cost Center No.</label>
                        <input id="txtCCNum" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="btnAddCC"    type="button" class="btn btn-success btn-sm"><i class="fa fa-plus me-1"></i>Add</button>
                        <button id="btnUpdateCC" type="button" class="btn btn-warning btn-sm"  style="display:none"><i class="fa fa-edit me-1"></i>Update</button>
                        <button id="btnDelCC"    type="button" class="btn btn-danger btn-sm"   style="display:none"><i class="fa fa-trash me-1"></i>Del</button>
                        <button id="btnCanCC"    type="button" class="btn btn-secondary btn-sm"><i class="fa fa-times"></i></button>
                    </div>
                </div>

                <div class="tel-grid-wrap">
                    <table id="tblCostCenters" class="table table-hover align-middle w-100" style="cursor:pointer">
                        <thead>
                            <tr>
                                <th>Cost Center Name</th>
                                <th>Cost Center No.</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Close
                </button>
            </div>

        </div>
    </div>
</div>


<!-- ══════════════════════════════════════════════════════════════════════════
     AD SYNC OVERLAY
     ══════════════════════════════════════════════════════════════════════════ -->
<div id="adSyncLoader" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,.55); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:12px; padding:40px 50px; text-align:center;
                box-shadow:0 8px 32px rgba(0,0,0,.25); min-width:280px;">
        <div style="margin-bottom:20px;">
            <svg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
