@{
    ViewData["Title"] = "Manage Telephone";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/addtelephone.css" asp-append-version="true" />
}

<div class="tc" id="view-telephone">

    <div class="telephone-form-container p-3">

        <ul class="nav nav-tabs" id="telephoneTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="add-tab" data-bs-toggle="tab" data-bs-target="#tab-add" type="button" role="tab">
                    <i class="fa fa-plus-circle me-1"></i>Add Telephone
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="assign-tab" data-bs-toggle="tab" data-bs-target="#tab-assign" type="button" role="tab">
                    <i class="fa fa-link me-1"></i>Assign Telephone
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <!-- ═════════════════════════ ADD TELEPHONE TAB ═════════════════════════ -->
            <div class="tab-pane fade show active" id="tab-add" role="tabpanel">

                <div class="tel-toolbar">
                    <button type="button" class="btn btn-add-tel btn-sm px-3"
                            data-bs-toggle="modal" data-bs-target="#telephoneModal"
                            onclick="openTelephoneModalForAdd()">
                        <i class="fa fa-plus me-1"></i>Add Telephone
                    </button>
                    <div class="tel-search">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input id="txtSearchTel" type="text" placeholder="Search telephones…" autocomplete="off" />
                    </div>
                </div>

                <!-- Desktop grid -->
                <div class="tel-grid-wrap">
                    <table id="tblTelephones" class="table table-hover align-middle w-100">
                        <thead>
                            <tr>
                                <th>Number</th>
                                <th>
                                    Provider
                                    <select id="filterProviderCol" class="tel-th-filter" onclick="event.stopPropagation()">
                                        <option value="">All</option>
                                    </select>
                                </th>
                                <th>Description</th>
                                <th>Account No.</th>
                                <th class="text-center">Assigned</th>
                                <th class="text-center">
                                    Business
                                    <select id="filterBusinessCol" class="tel-th-filter" onclick="event.stopPropagation()">
                                        <option value="">All</option>
                                        <option value="Business">Business</option>
                                        <option value="Personal">Personal</option>
                                    </select>
                                </th>
                                <th>
                                    Line Type
                                    <select id="filterLineTypeCol" class="tel-th-filter" onclick="event.stopPropagation()">
                                        <option value="">All</option>
                                    </select>
                                </th>
                                <th class="text-center" style="width:60px">Edit</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <!-- Mobile card list (≤768px, .tel-grid-wrap hidden by media query) -->
                <div id="mobTelCards"></div>
            </div>

            <!-- ═════════════════════════ ASSIGN TELEPHONE TAB ═════════════════════════ -->
            <div class="tab-pane fade" id="tab-assign" role="tabpanel">

                <div class="tel-toolbar">
                    <button type="button" class="btn btn-add-tel btn-sm px-3"
                            data-bs-toggle="modal" data-bs-target="#assignModal"
                            onclick="openAssignModalForAdd()">
                        <i class="fa fa-plus me-1"></i>Assign Telephone
                    </button>
                    <div class="tel-search">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input id="txtSearchAsg" type="text" placeholder="Search assignments…" autocomplete="off" />
                    </div>
                </div>

                <div class="tel-grid-wrap">
                    <table id="tblAssignNo" class="table table-hover align-middle w-100">
                        <thead>
                            <tr>
                                <th>Number</th>
                                <th>Employee Name</th>
                                <th>Emp No.</th>
                                <th>Cost Center</th>
                                <th>Description</th>
                                <th class="text-end">Allowance</th>
                                <th class="text-end">Business</th>
                                <th>Status</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th class="text-center" style="width:60px">Edit</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <!-- Mobile card list (≤768px, .tel-grid-wrap hidden by media query) -->
                <div id="mobAsgCards"></div>
            </div>

        </div>
    </div>
</div>


<!-- ═════════════════════════ TELEPHONE MODAL (Add / Edit) ═════════════════════════ -->
<div class="modal fade tel-modal" id="telephoneModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-phone"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title" id="telephoneModalTitle">Add Telephone</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

            </div>

            <div class="modal-body">
                <input type="hidden" id="hidID" />

                <!-- Row 1: Provider · Telephone No · Description -->
                <div class="row g-4 tel-row">
                    <div class="col-md-4">
                        <label for="cmbProvider" class="form-label tel-lbl">
                            <i class="fa fa-network-wired me-1"></i>Select Provider
                        </label>
                        <select id="cmbProvider" class="form-select tel-input">
                            <option value="">Select Provider</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="txtSubNo" class="form-label tel-lbl">
                            <i class="fa fa-phone me-1"></i>Telephone No
                        </label>
                        <input id="txtSubNo" type="text" class="form-control tel-input" />
                    </div>
                    <div class="col-md-4">
                        <label for="txtSubDesc" class="form-label tel-lbl">
                            <i class="fa fa-align-left me-1"></i>Description
                        </label>
                        <input id="txtSubDesc" type="text" class="form-control tel-input" />
                    </div>
                </div>

                <!-- Row 2: Business or Personal · Line Type · Account No -->
                <div class="row g-4 tel-row tel-row-last">
                    <div class="col-md-4">
                        <label for="cmbType" class="form-label tel-lbl">
                            <i class="fa fa-user-tag me-1"></i>Business or Personal
                        </label>
                        <select id="cmbType" class="form-select tel-input">
                            <option value="False">Personal</option>
                            <option value="True" selected>Business</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="cmbLineType" class="form-label tel-lbl">
                            <i class="fa fa-sitemap me-1"></i>Line Type
                        </label>
                        <select id="cmbLineType" class="form-select tel-input">
                            <option value="">-- Select Line Type --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="txtAccountNo" class="form-label tel-lbl">
                            <i class="fa fa-hashtag me-1"></i>Account No
                        </label>
                        <input id="txtAccountNo" type="text" class="form-control tel-input" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Cancel
                </button>
                <button id="btnAdd" type="button" class="btn btn-success">
                    <i class="fa fa-plus-circle me-1"></i>Add
                </button>
                <button id="btnUpdate" type="button" class="btn btn-warning" style="display:none">
                    <i class="fa fa-edit me-1"></i>Update
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ═════════════════════════ ASSIGN MODAL (Add / Edit) ═════════════════════════ -->
<div class="modal fade tel-modal" id="assignModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-link"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title" id="assignModalTitle">Assign Telephone</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input id="hidAID" type="hidden" />

                <!-- Row 1: Employee · Cost Center · Number · Line Status -->
                <div class="row g-4 tel-row">
                    <div class="col-md-3">
                        <label class="form-label tel-lbl">
                            <i class="fa fa-user-tie me-1"></i>Employee
                        </label>
                        <div class="tel-picker" data-picker="employee">
                            <input type="hidden" id="cmbEmployee" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Employee
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search name or number…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label tel-lbl">
                            <i class="fa fa-building me-1"></i>Cost Center
                        </label>
                        <div class="tel-picker" data-picker="costCenter">
                            <input type="hidden" id="cmbCostCenter" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Cost Center
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search cost center…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label tel-lbl">
                            <i class="fa fa-phone me-1"></i>Number
                        </label>
                        <div class="tel-picker" data-picker="number">
                            <input type="hidden" id="cmbNumber" />
                            <button type="button" class="form-select tel-input tel-picker-btn is-placeholder"
                                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                Select Number
                            </button>
                            <div class="dropdown-menu tel-picker-menu">
                                <div class="tel-picker-search-wrap">
                                    <input type="text" class="tel-picker-search" placeholder="Search number…" autocomplete="off" />
                                </div>
                                <div class="tel-picker-list"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label for="cmbLineStatus" class="form-label tel-lbl">
                            <i class="fa fa-shuffle me-1"></i>Line Status
                        </label>
                        <select id="cmbLineStatus" class="form-select tel-input">
                            <option value="0" selected>None</option>
                            <option value="1">Connected</option>
                            <option value="2">Disconnected</option>
                            <option value="3">Transferred</option>
                        </select>
                    </div>
                </div>

                <!-- Row 2: Allowance Limit · Business Limit · Start Date · End Date -->
                <div class="row g-4 tel-row tel-row-last">
                    <div class="col-md-3">
                        <label for="txtAlwLimit" class="form-label tel-lbl">
                            <i class="fa fa-wallet me-1"></i>Allowance Limit
                        </label>
                        <input id="txtAlwLimit" type="number" step="0.001" class="form-control tel-input" />
                    </div>
                    <div class="col-md-3">
                        <label for="txtBusLimit" class="form-label tel-lbl">
                            <i class="fa fa-briefcase me-1"></i>Business Limit
                        </label>
                        <input id="txtBusLimit" type="number" step="0.001" class="form-control tel-input" />
                    </div>
                    <div class="col-md-3">
                        <label for="cmbStartDate" class="form-label tel-lbl">
                            <i class="fa fa-calendar-day me-1"></i>Start Date
                        </label>
                        <input type="date" id="cmbStartDate" class="form-control tel-input" />
                    </div>
                    <div class="col-md-3">
                        <label for="cmbEndDate" class="form-label tel-lbl">
                            <i class="fa fa-calendar-day me-1"></i>End Date
                        </label>
                        <input type="date" id="cmbEndDate" class="form-control tel-input" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Cancel
                </button>
                <button id="btnAssign" type="button" class="btn btn-success">
                    <i class="fa fa-plus me-1"></i>Assign
                </button>
                <button id="btnUpdateAsg" type="button" class="btn btn-warning" style="display:none">
                    <i class="fa fa-edit me-1"></i>Update
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AddTelephone.js" asp-append-version="true"></script>
}
