@{
    ViewData["Title"] = "Import Mobile Bills";
    Layout = "_Layout";
}

<div class="imp-page" id="view-import-invoice">

    <ul class="nav nav-tabs" id="importTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-import" data-bs-toggle="tab"
                    data-bs-target="#pane-import" type="button" role="tab">
                <i class="fa fa-file-import me-1"></i>Import
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-mapping" data-bs-toggle="tab"
                    data-bs-target="#pane-mapping" type="button" role="tab">
                <i class="fa fa-map me-1"></i>Excel Mapping
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- ══════════════════════════════════════════════════
             IMPORT TAB
             ══════════════════════════════════════════════════ -->
        <div class="tab-pane fade show active" id="pane-import" role="tabpanel">

            <div class="imp-form-card imp-wizard">

                <!-- ── Step 1: Provider · Year · Month ───────────────────────── -->
                <div class="imp-step imp-step--1">
                    <div class="imp-step-head">
                        <span class="imp-step-num">1</span>
                        <span class="imp-step-title">Choose Provider &amp; Billing Period</span>
                    </div>
                    <div class="imp-step-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="tel-lbl"><i class="fa fa-building me-1"></i>Select Provider</label>
                                <select id="cmbProvider" class="form-select tel-input imp-sel imp-sel--provider">
                                    <option value="">Select Provider</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="tel-lbl"><i class="fa fa-calendar-alt me-1"></i>Select Year</label>
                                <select id="cmbYear" class="form-select tel-input imp-sel imp-sel--year">
                                    <option value="">Select Year</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="tel-lbl"><i class="fa fa-calendar me-1"></i>Select Month</label>
                                <select id="cmbMonth" class="form-select tel-input imp-sel imp-sel--month">
                                    <option value="0">Select Month</option>
                                    <option value="1">January</option>   <option value="2">February</option>
                                    <option value="3">March</option>     <option value="4">April</option>
                                    <option value="5">May</option>       <option value="6">June</option>
                                    <option value="7">July</option>      <option value="8">August</option>
                                    <option value="9">September</option> <option value="10">October</option>
                                    <option value="11">November</option> <option value="12">December</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Steps 2 & 3 sit side by side ──────────────────────────── -->
                <div class="imp-step-row">

                <!-- ── Step 2: File + Upload ─────────────────────────────────── -->
                <div class="imp-step imp-step--2">
                    <div class="imp-step-head">
                        <span class="imp-step-num">2</span>
                        <span class="imp-step-title">Select &amp; Upload File</span>
                    </div>
                    <div class="imp-step-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-7">
                                <label class="tel-lbl"><i class="fa fa-file-upload me-1"></i>Select File (.xls / .xlsx)</label>
                                <input type="file" class="form-control tel-input imp-file" id="jqxFileUpload"
                                       accept=".xls,.xlsx,.mde,.mdb" />
                                <div id="lblFileName" class="imp-file-name mt-1"></div>
                            </div>
                            <div class="col-md-5">
                                <button id="btnUpload" type="button" class="imp-btn imp-btn--upload w-100" style="display:none">
                                    <i class="fa fa-cloud-arrow-up me-1"></i>Upload File
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Step 3: Select Sheet + Submit (revealed after upload) ─── -->
                <div class="imp-step imp-step--3" id="stepSheet" style="display:none">
                    <div class="imp-step-head">
                        <span class="imp-step-num">3</span>
                        <span class="imp-step-title">Select Sheet &amp; Submit</span>
                    </div>
                    <div class="imp-step-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-7">
                                <label class="tel-lbl"><i class="fa fa-file-excel me-1"></i>Select Sheet</label>
                                <select id="cmbSheet" class="form-select tel-input imp-sel imp-sel--sheet">
                                    <option value="">Select Sheet</option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <button id="btnSubmit" type="button" class="imp-btn imp-btn--submit w-100" style="display:none">
                                    <i class="fa fa-paper-plane me-1"></i>Submit
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                </div><!-- /imp-step-row -->

                <!-- ── Step 4: Total Amount + Process Bill (revealed after submit) -->
                <div class="imp-step imp-step--4" id="stepResult" style="display:none">
                    <div class="imp-step-head">
                        <span class="imp-step-num">4</span>
                        <span class="imp-step-title">Review &amp; Process</span>
                    </div>
                    <div class="imp-step-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="tel-lbl"><i class="fa fa-money-bill-wave me-1"></i>Total Amount</label>
                                <div id="lblBillAmount" class="imp-amount-display"></div>
                            </div>
                            <div class="col-md-4">
                                <button id="btnProcess" type="button" class="imp-btn imp-btn--process w-100" style="display:none">
                                    <i class="fa fa-cog me-1"></i>Process Bill
                                </button>
                            </div>
                            <div class="col-md-4">
                                <button id="btnSave" type="button" class="imp-btn imp-btn--save w-100" style="display:none">
                                    <i class="fa fa-save me-1"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /imp-form-card -->

            <!-- Error records grid (shown when import has null rows) -->
            <div id="impImportSection" style="display:none" class="mb-3">
                <div class="tel-grid-wrap">
                    <div class="tel-toolbar">
                        <span class="fw-semibold" style="font-size:14px;color:#b91c1c">
                            <i class="fa fa-triangle-exclamation me-1"></i>Records with missing data — fix before processing
                        </span>
                    </div>
                    <table id="tblImport" class="table table-hover align-middle w-100">
                        <thead>
                            <tr>
                                <th>Sub No</th>
                                <th>Bill Date</th>
                                <th>Call Date</th>
                                <th>Trans Type</th>
                                <th>Description</th>
                                <th class="text-end">Amount</th>
                                <th>Duration</th>
                                <th>Call Time</th>
                                <th class="text-center" style="width:60px">Edit</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <!-- Upload History grid -->
            <div class="tel-grid-wrap">
                <div class="tel-toolbar">
                    <span class="fw-semibold" style="font-size:14px;color:var(--tx2,#334155)">
                        <i class="fa fa-history me-1" style="color:var(--teal,#2ab3bf)"></i>Upload History
                    </span>
                    <div class="tel-search">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input id="txtSearchHistory" type="text" placeholder="Search history…" autocomplete="off" />
                    </div>
                </div>
                <table id="tblHistory" class="table table-hover align-middle w-100">
                    <thead>
                        <tr>
                            <th>File Name</th>
                            <th>Bill Date</th>
                            <th>Upload Date</th>
                            <th>Provider</th>
                            <th class="text-end">Bill Amount</th>
                            <th id="thDelete" class="text-center" style="width:90px">Delete</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Export -->
            <div class="mt-3 text-end">
                <button id="btnExportExcel" type="button" class="imp-btn-export">
                    <svg fill="#fff" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 50 50">
                        <path d="M28.8125.03125L.8125 5.34375C.339844 5.433594 0 5.863281 0 6.34375L0 43.65625C0
                            44.136719.339844 44.566406.8125 44.65625L28.8125 49.96875C28.875 49.980469 28.9375 50
                            29 50C29.230469 50 29.445313 49.929688 29.625 49.78125C29.855469 49.589844 30
                            49.296875 30 49L30 1C30 .703125 29.855469.410156 29.625.21875C29.394531.0273438
                            29.105469-.0234375 28.8125.03125ZM32 6L32 13L34 13L34 15L32 15L32 20L34 20L34 22L32
                            22L32 27L34 27L34 29L32 29L32 35L34 35L34 37L32 37L32 44L47 44C48.101563 44 49
                            43.101563 49 42L49 8C49 6.898438 48.101563 6 47 6ZM36 13L44 13L44 15L36 15ZM6.6875
                            15.6875L11.8125 15.6875L14.5 21.28125C14.710938 21.722656 14.898438 22.265625
                            15.0625 22.875L15.09375 22.875C15.199219 22.511719 15.402344 21.941406 15.6875
                            21.21875L18.65625 15.6875L23.34375 15.6875L17.75 24.9375L23.5 34.375L18.53125
                            34.375L15.28125 28.28125C15.160156 28.054688 15.035156 27.636719 14.90625
                            27.03125L14.875 27.03125C14.8125 27.316406 14.664063 27.761719 14.4375
                            28.34375L11.1875 34.375L6.1875 34.375L12.15625 25.03125ZM36 20L44 20L44 22L36
                            22ZM36 27L44 27L44 29L36 29ZM36 35L44 35L44 37L36 37Z"/>
                    </svg>
                    Export to Excel
                </button>
            </div>

        </div><!-- /pane-import -->


        <!-- ══════════════════════════════════════════════════
             EXCEL MAPPING TAB
             ══════════════════════════════════════════════════ -->
        <div class="tab-pane fade" id="pane-mapping" role="tabpanel">

            <div class="imp-form-card">

                <!-- Row 1: Provider · Type · Show Prev Setting · Reset -->
                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-building me-1"></i>Select Provider</label>
                        <select id="cmbProvider2" class="form-select tel-input">
                            <option value="">Select Provider</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="tel-lbl"><i class="fa fa-list me-1"></i>Select Type</label>
                        <select id="SelectType" class="form-select tel-input">
                            <option value="0">Select Type</option>
                            <option value="1">Excel</option>
                            <option value="2">DataBase</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button id="btnPrevSetting" type="button" class="btn btn-secondary w-100">
                            <i class="fa fa-history me-1"></i>Show Prev Setting
                        </button>
                    </div>
                    <div class="col-md-3">
                        <button id="btnReset" type="button" class="btn btn-danger w-100">
                            <i class="fa fa-redo me-1"></i>Reset
                        </button>
                    </div>
                </div>

                <!-- Excel section (shown when Type = Excel) -->
                <div id="SelectFile">
                    <div class="row g-3 mb-3 align-items-end">
                        <div class="col-md-3">
                            <label class="tel-lbl"><i class="fa fa-file-upload me-1"></i>Select File</label>
                            <input type="file" class="form-control tel-input" id="jqxFileUpload2"
                                   accept=".xls,.xlsx,.mde,.mdb" />
                            <div id="lblFileName2" class="form-text mt-1"></div>
                        </div>
                        <div class="col-md-3">
                            <label class="tel-lbl"><i class="fa fa-file-excel me-1"></i>Select Sheet</label>
                            <select id="cmbSheet2" class="form-select tel-input">
                                <option value="">Select Sheet</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button id="btnUpload2" type="button" class="btn btn-add-tel w-100">
                                <i class="fa fa-upload me-1"></i>Upload New Setting
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Database section (shown when Type = DataBase) -->
                <div id="DataBase" class="imp-db-section" style="display:none">
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="tel-lbl"><i class="fa fa-database me-1"></i>Database Connection String</label>
                            <input id="txtDataBase" type="text" class="form-control tel-input"
                                   value="Data Source=(localdb)\Projects;Initial Catalog=TIS;Integrated Security=True;" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3 align-items-end">
                        <div class="col-md-3">
                            <button id="btnTestConn" type="button" class="btn btn-primary">
                                <i class="fa fa-plug me-1"></i>Test Connection
                            </button>
                        </div>
                        <div class="col-md-9">
                            <div id="connStatus"></div>
                        </div>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label class="tel-lbl"><i class="fa fa-eye me-1"></i>Select View / Table</label>
                            <select id="cmbViews" class="form-select tel-input">
                                <option value="">Select View</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button id="btnUpload3" type="button" class="btn btn-add-tel">
                                <i class="fa fa-upload me-1"></i>Upload DB Setting
                            </button>
                        </div>
                    </div>
                </div>

            </div><!-- /imp-form-card (controls) -->

            <!-- Field Mapping Configuration -->
            <div class="imp-form-card">
                <h6 class="fw-bold mb-3" style="color:#1a3a6e">
                    <i class="fa fa-map me-1" style="color:var(--teal,#2ab3bf)"></i>Field Mapping Configuration
                </h6>
                <table class="table imp-mapping-table">
                    <thead>
                        <tr>
                            <th style="width:35%">Field Name</th>
                            <th>Excel / DB Column Mapping</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td><strong><i class="fa fa-phone me-1"></i>1) Telephone Number</strong></td><td><select id="dd1" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-calendar me-1"></i>2) Bill Date</strong></td><td><select id="dd2" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-calendar-check me-1"></i>3) Transaction Date</strong></td><td><select id="dd3" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-phone-volume me-1"></i>4) Call Type</strong></td><td><select id="dd4" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-mobile-alt me-1"></i>5) Destination No</strong></td><td><select id="dd5" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-clock me-1"></i>6) Time of Call</strong></td><td><select id="dd6" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-hourglass-half me-1"></i>7) Duration (Sec)</strong></td><td><select id="dd7" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                        <tr><td><strong><i class="fa fa-money-bill-wave me-1"></i>8) Amount (KD)</strong></td><td><select id="dd8" class="form-select tel-input"><option value="">Select Column</option></select></td></tr>
                    </tbody>
                </table>

                <div class="d-flex gap-2 mt-3">
                    <button id="btnUpdate" type="button" class="btn btn-warning">
                        <i class="fa fa-edit me-1"></i>Update
                    </button>
                    <button id="Button1" type="button" class="btn btn-warning" style="display:none">
                        <i class="fa fa-database me-1"></i>Update DB
                    </button>
                </div>
            </div>

        </div><!-- /pane-mapping -->

    </div><!-- /tab-content -->
</div><!-- /imp-page -->


<!-- ══════════════════════════════════════════════════════════════════════════
     EDIT IMPORT RECORD MODAL
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade tel-modal" id="editImportModal" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-pen-to-square"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title">Edit Import Record</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editImportId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="tel-lbl"><i class="fa fa-phone me-1"></i>Subscription No (SUB_NO)</label>
                        <input id="editSubNo" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>
                    <div class="col-12">
                        <label class="tel-lbl"><i class="fa fa-calendar me-1"></i>Call Date</label>
                        <input id="editCallDate" type="date" class="form-control tel-input" />
                    </div>
                    <div class="col-12">
                        <label class="tel-lbl"><i class="fa fa-money-bill-wave me-1"></i>Amount</label>
                        <input id="editAmount" type="text" class="form-control tel-input" autocomplete="off" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Cancel
                </button>
                <button id="btnSaveImportRow" type="button" class="btn btn-success">
                    <i class="fa fa-check me-1"></i>Save
                </button>
            </div>

        </div>
    </div>
</div>


<!-- ══════════════════════════════════════════════════════════════════════════
     BILL DETAILS MODAL  (shown after ProcessBill success)
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade tel-modal" id="billDetailsModal" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header tel-modal-hdr">
                <div class="tel-modal-icon"><i class="fa fa-chart-bar"></i></div>
                <div class="flex-grow-1">
                    <div class="tel-modal-title">Bill Uploaded Successfully</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="imp-summary-row">
                    <div class="imp-summary-card">
                        <div class="imp-summary-label">Unregistered Mobile Numbers</div>
                        <div class="imp-summary-count" id="bdCount1">0</div>
                        <div class="imp-summary-amount">Amount: <span id="bdAmt1">0.000</span> KD</div>
                    </div>
                    <div class="imp-summary-card imp-summary-card--warn">
                        <div class="imp-summary-label">Not Assigned to Any User</div>
                        <div class="imp-summary-count" id="bdCount2">0</div>
                        <div class="imp-summary-amount">Amount: <span id="bdAmt2">0.000</span> KD</div>
                    </div>
                    <div class="imp-summary-card imp-summary-card--warn">
                        <div class="imp-summary-label">Assigned Outside Valid Dates</div>
                        <div class="imp-summary-count" id="bdCount3">0</div>
                        <div class="imp-summary-amount">Amount: <span id="bdAmt3">0.000</span> KD</div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button id="btnBdSendEmail" type="button" class="btn btn-add-tel">
                    <i class="fa fa-envelope me-1"></i>Send Email
                </button>
                <button id="btnBdGotoUnassigned" type="button" class="btn btn-secondary">
                    <i class="fa fa-arrow-right me-1"></i>Go to Unassigned Bills
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa fa-times me-1"></i>Close
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ImportInvoice.js" asp-append-version="true"></script>
}
